# ==========================================
# FlowStock - Variables de Entorno
# ==========================================

# Configuración del servidor Node.js
PORT=3000
NODE_ENV=production

# Configuración de Base de Datos AWS RDS (PostgreSQL)
DB_HOST=inventario-db.xxxx.us-east-1.rds.amazonaws.com 
DB_USER=flowuser
DB_PASSWORD=flow_secure_password_123
DB_NAME=flowstock
DB_PORT=5432

# Variables requeridas por la imagen de PostgreSQL (Docker)
POSTGRES_USER=flowuser
POSTGRES_PASSWORD=flow_secure_password_123
POSTGRES_DB=flowstock
